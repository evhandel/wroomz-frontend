PORT=3006
REACT_APP_API_URL=http://localhost:3005/api

# PostHog analytics (optional). Without a key, analytics is a no-op.
# Get the Project API Key from PostHog -> Settings -> Project.
# Events are proxied through /ingest (see setupProxy.js / nginx.conf) to dodge
# ad blockers, so no host override is needed. Set the host only to opt out of
# the proxy (e.g. https://eu.i.posthog.com).
REACT_APP_PUBLIC_POSTHOG_KEY=
# Analytics is disabled in dev by default. Set to true to test it locally.
# REACT_APP_POSTHOG_DEV=true